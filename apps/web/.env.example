# Agentromatic Web App — Example Environment Variables
# Copy this file to `.env` for local development.
#
# NOTE:
# - Do NOT commit your real `.env` file.
# - Values below are placeholders.
# - Some variables will only be needed once Convex + Auth are fully wired.

# ----------------------------
# Convex
# ----------------------------
# The Convex deployment URL (set after `convex dev` / `convex deploy`).
# Example format:
# VITE_CONVEX_URL=https://<your-deployment>.convex.cloud
VITE_CONVEX_URL=https://lovable-flamingo-552.convex.cloud

# Optional: if you later use Convex HTTP Actions or custom endpoints and want
# to reference a public base URL from the client, add it here.
# VITE_CONVEX_HTTP_URL=

# ----------------------------
# Auth (planned: Clerk)
# ----------------------------
# Public (client-side) key. Safe to expose to the browser.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: if you host Clerk under a custom domain, set these.
# VITE_CLERK_FRONTEND_API=
# VITE_CLERK_SIGN_IN_URL=/sign-in
# VITE_CLERK_SIGN_UP_URL=/sign-up

# ----------------------------
# Observability (optional MVP)
# ----------------------------
# PostHog project API key (client-side). Safe to expose to the browser.
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry DSN for client (optional).
# VITE_SENTRY_DSN=

# ----------------------------
# App / Build Metadata (optional)
# ----------------------------
# Useful for local toggles or environment badges.
# VITE_APP_ENV=local
# VITE_PUBLIC_BASE_URL=http://localhost:5173

# ----------------------------
# Feature Flags (optional)
# ----------------------------
# VITE_FEATURE_NL_WORKFLOWS=false
# VITE_FEATURE_VISUAL_BUILDER=false
