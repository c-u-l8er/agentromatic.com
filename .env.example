# Agentromatic — Example Environment Variables
#
# Copy this file to `.env` in the repo root and fill in values as needed.
# Do NOT commit `.env` (it is gitignored).
#
# Notes:
# - This repo uses a monorepo layout:
#   - apps/web (frontend)
#   - convex (backend)
# - Some variables are only needed once you wire Clerk/auth, billing, or integrations.
# - Convex will also manage its own environment variables via `npx convex env set`
#   for hosted deployments. For local dev, `.env` can still be helpful for the web app.

###############################################################################
# Frontend (apps/web)
###############################################################################

# Convex deployment URL used by the frontend client.
# You will get this after running `npx convex dev` (it prints a URL).
# Example (NOT REAL): https://your-deployment.convex.cloud
VITE_CONVEX_URL=

# Public app URL (optional; used for building absolute URLs, redirects, etc.)
# Example: http://localhost:5173
VITE_PUBLIC_APP_URL=http://localhost:5173

###############################################################################
# Auth (Clerk) — planned stack (optional until auth is wired)
###############################################################################

# Clerk publishable key (frontend)
VITE_CLERK_PUBLISHABLE_KEY=

# Clerk secret key (server-only; should NOT be exposed to the browser)
CLERK_SECRET_KEY=

# Clerk webhook signing secret (server-only; used if you consume Clerk webhooks)
CLERK_WEBHOOK_SECRET=

###############################################################################
# Observability (optional)
###############################################################################

# Sentry DSN (browser)
VITE_SENTRY_DSN=

# Sentry DSN (server)
SENTRY_DSN=

# PostHog (browser)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

###############################################################################
# AI Providers (planned; optional until AI nodes are implemented)
###############################################################################

# Anthropic (Claude) API Key (server-only)
ANTHROPIC_API_KEY=

# OpenAI API Key (server-only)
OPENAI_API_KEY=

###############################################################################
# Billing (Lemon Squeezy) — planned (optional until billing is wired)
###############################################################################

LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

###############################################################################
# Integrations (planned; optional until connector nodes are implemented)
###############################################################################

# Slack OAuth (server-only)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Twilio (server-only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Resend (server-only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

###############################################################################
# Generic / app settings
###############################################################################

# Environment label (used for debugging/logging)
# Suggested: local | dev | staging | prod
APP_ENV=local

# Set to "true" to enable more verbose logs in development
DEBUG=false
